Bootstrap: docker
From: ubuntu:24.04

%labels
    Maintainer openai-codex
    Description Apptainer image with OpenAI Codex CLI installed

%environment
    export PATH=/root/.pixi/bin:/usr/local/bin:$PATH

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        git \
        libx11-6 \
        libxext6 \
        libxrender1 \
        nodejs \
        npm \
        poppler-utils \
        ripgrep
    rm -rf /var/lib/apt/lists/*

    npm install -g @openai/codex

    # Install pixi (Python/multi-language package manager)
    curl -fsSL https://pixi.sh/install.sh | bash

%runscript
    exec /usr/local/bin/codex "$@"
