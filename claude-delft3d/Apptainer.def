Bootstrap: docker
From: ubuntu:24.04

%labels
    Maintainer github-copilot
    Description Apptainer image with Claude Code CLI installed

%environment
    #/root/.local/bin for claude
    export PATH=/root/.pixi/bin:/root/.local/bin:/usr/local/bin:$PATH

%files
    ../delft3d/opt /
    CLAUDE.md /opt/CLAUDE.md

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        git \
        poppler-utils \
        ripgrep
    rm -rf /var/lib/apt/lists/*

    curl -fsSL https://claude.ai/install.sh | bash

    # Install pixi (Python/multi-language package manager)
    curl -fsSL https://pixi.sh/install.sh | bash

%runscript
    exec claude "$@"
