Bootstrap: docker
From: ubuntu:24.04

%labels
    Maintainer github-copilot
    Description Apptainer image with GitHub Copilot CLI installed

%environment
    export PATH=/root/.pixi/bin:/usr/local/bin:$PATH

%files
    ../delft3d/opt /
    CLAUDE.md /opt/README.md

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        git \
        poppler-utils \
        ripgrep
    rm -rf /var/lib/apt/lists/*

    curl -fsSL https://gh.io/copilot-install | bash

    # Install pixi (Python/multi-language package manager)
    curl -fsSL https://pixi.sh/install.sh | bash

%runscript
    exec /usr/local/bin/copilot "$@"
